# Config for deploy/deploy.sh. Copy to deploy/deploy.env (git-ignored) and fill in.
# CLI flags to deploy.sh override anything set here.

# --- Remote target ----------------------------------------------------------
# SSH target for the VPS: user@host or an ssh Host alias from ~/.ssh/config.
# Leave EMPTY to run the deploy locally (i.e. when you run deploy.sh ON the box).
# NOTE: deploy.env is git-ignored — put the real host here, never in this example.
DEPLOY_SSH=user@your-vps-host

# Absolute path to the cloned repo on the box (required when DEPLOY_SSH is set).
DEPLOY_REMOTE_PATH=/opt/send

# --- What to deploy ---------------------------------------------------------
# Branch the box pulls from origin and the canonical public domain Caddy serves.
DEPLOY_BRANCH=main
SEND_DOMAIN=send.example.com
