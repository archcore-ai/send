# Copy to .env and fill in. Compose substitutes ${SEND_DOMAIN} and sendd reads
# every SEND_* key below via env_file.

# Public DuckDNS host for this instance (no scheme), e.g. send-abcd.duckdns.org
SEND_DOMAIN=send-xxxx.duckdns.org
# External base URL used in the links sendd returns.
SEND_PUBLIC_URL=https://send-xxxx.duckdns.org

# --- Lifecycle (public instance: tight, to bound abuse + storage) ---
# Open instance default is 1h; raise SEND_MAX_TTL up to 168h (7d) if you want.
SEND_DEFAULT_TTL=1h
SEND_MAX_TTL=24h
SEND_GC_INTERVAL=2m

# --- Size caps (bytes) — keep aligned with Caddy request_body max_size ---
SEND_MAX_TOTAL_BYTES=26214400
SEND_MAX_PART_BYTES=26214400
SEND_MAX_PART_COUNT=64

# --- Rate limits (per client IP per window; 0 disables a bucket) ---
SEND_RATE_CREATE_PER_MIN=30
SEND_RATE_UPLOAD_PER_MIN=240
SEND_RATE_WINDOW=1m

# Optional team mode: set a bearer token to require it on writes (create,
# upload, finalize). Reads/redeem/download stay anonymous (the link is the gate).
# Leave empty for an anonymous, open public instance.
SEND_TEAM_TOKEN=

# Storage paths inside the container's /data volume (usually leave as-is).
SEND_DB_PATH=/data/sends.db
SEND_BLOB_DIR=/data/blobs
