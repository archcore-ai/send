#!/usr/bin/env python3
"""Deterministic fake `age-keygen` for skill tests when real age is unavailable."""
import sys

args = sys.argv[1:]
RECIPIENT = "age1fakerecipient00000000000000000000000000000000000000000000"
SECRET = "AGE-SECRET-KEY-1FAKE00000000000000000000000000000000000000000000000"

if "-y" in args:
    # Derive recipient from an identity file (value is irrelevant for identity crypto).
    print(RECIPIENT)
    sys.exit(0)

content = (
    "# created by fake age-keygen\n"
    f"# public key: {RECIPIENT}\n"
    f"{SECRET}\n"
)
if "-o" in args:
    out = args[args.index("-o") + 1]
    with open(out, "w", encoding="utf-8") as fh:
        fh.write(content)
    sys.stderr.write(f"Public key: {RECIPIENT}\n")
else:
    sys.stdout.write(content)
